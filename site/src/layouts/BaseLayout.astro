---
/**
 * BaseLayout.astro — Four Winds Roots Pharmacy
 * Full accessible site shell: head, header, main slot, footer, mobile action bar.
 * AODA / WCAG 2.2 AA compliant structure.
 */

import '../styles/global.css';
import schemaData from '../data/schema.json';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  /**
   * Set true on any page that collects health information (refills, transfers,
   * delivery request, MedsCheck booking). PHIPA obligation: no analytics firing
   * on pages where patients submit health data.
   */
  noAnalytics?: boolean;
}

const {
  title,
  description = 'Four Winds Roots Pharmacy — holistic pharmacy, optical & wellness centre at 3932A Keele St, North York. Prescription refills, transfers, free delivery, and more. Call (416) 398-8200.',
  canonicalUrl,
  noAnalytics = false,
} = Astro.props;

const canonical = canonicalUrl ?? Astro.url.href;

// Remove @comment_ fields from schema for output — they're dev annotations only
const schemaJsonLd = JSON.stringify(
  schemaData,
  (key, value) => (key.startsWith('@comment') ? undefined : value),
  2
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <!-- TODO: add og:image once pharmacy photos are taken (storefront + team) -->

    <!-- Favicon -->
    <!-- TODO: add favicon files once logo is commissioned -->
    <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->

    <!-- Performance: preconnect to Google Fonts before the stylesheet request -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />

    <!-- Google Fonts: Lora (heading) + Inter (body) — subset for performance -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;700&display=swap"
    />

    <!-- JSON-LD structured data (Pharmacy schema) -->
    <script type="application/ld+json" set:html={schemaJsonLd}></script>

    <!--
      Privacy-friendly analytics — Plausible (no cookies, GDPR/PHIPA safe).
      NOT loaded on health-data form pages (noAnalytics = true).
      TODO: confirm data-domain matches final registered domain before go-live.
      Font-src and style-src in netlify.toml CSP also need fonts.googleapis.com
      and fonts.gstatic.com added before go-live.
    -->
    {!noAnalytics && (
      <script
        defer
        data-domain="fourwindsrootspharmacy.ca"
        src="https://plausible.io/js/script.js"
      ></script>
    )}
  </head>

  <body>
    <!-- Skip navigation link — keyboard/screen-reader users jump to content (AODA 2.4.1) -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- ── Site header ──────────────────────────────────────────────────── -->
    <header class="site-header" role="banner">
      <div class="container site-header__inner">

        <!-- Logo / brand wordmark -->
        <!-- TODO: replace text logo with <img> once logo is commissioned -->
        <a href="/" class="logo" aria-label="Four Winds Roots Pharmacy — go to homepage">
          <span class="logo__text">Four Winds Roots Pharmacy</span>
        </a>

        <!-- Primary navigation -->
        <nav aria-label="Main navigation" class="site-nav">
          <button
            class="site-nav__toggle"
            aria-expanded="false"
            aria-controls="main-nav-list"
            aria-label="Open navigation menu"
          >
            <span class="site-nav__hamburger" aria-hidden="true">&#9776;</span>
          </button>

          <ul class="site-nav__list" id="main-nav-list" role="list">
            <li>
              <a href="/services/refills" class="site-nav__link">Services</a>
            </li>
            <li>
              <a href="/holistic-wellness" class="site-nav__link">Holistic Wellness</a>
            </li>
            <li>
              <a href="/optical-wellness" class="site-nav__link">Optical</a>
            </li>
            <li>
              <a href="/about" class="site-nav__link">About</a>
            </li>
            <li>
              <a href="/contact" class="site-nav__link">Contact</a>
            </li>
          </ul>
        </nav>

        <!-- Persistent header CTAs — the most important conversion actions -->
        <div class="site-header__ctas" role="group" aria-label="Quick actions">
          <a
            href="#"
            class="btn btn-call tel-protected"
            data-p0="4" data-p1="163" data-p2="98" data-p3="8200"
            aria-label="Call 4 1 6 - 3 9 8 - 8 2 0 0"
          >
            <!-- Inline SVG phone icon -->
            <svg
              aria-hidden="true"
              focusable="false"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.6 4.38 2 2 0 0 1 3.57 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            Call Us
          </a>
          <a href="/services/transfers" class="btn btn-transfer">Transfer Rx</a>
        </div>

      </div>
    </header>

    <!-- ── Main content ─────────────────────────────────────────────────── -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- ── Site footer ─────────────────────────────────────────────────── -->
    <footer class="site-footer" role="contentinfo">
      <div class="container site-footer__inner">

        <!-- NAP block — Name / Address / Phone (SEO critical, must match GBP exactly) -->
        <section class="footer-nap" aria-labelledby="footer-nap-heading">
          <h2 id="footer-nap-heading" class="footer-nap__name">Four Winds Roots Pharmacy</h2>
          <address class="footer-nap__address" aria-label="Pharmacy address">
            <p>
              <span class="footer-nap__street">3932A Keele St</span><br />
              <span class="footer-nap__city">North York, ON M3J 1N8</span>
            </p>
            <p>
              <a
                href="#"
                class="footer-nap__phone tel-protected"
                data-p0="4" data-p1="163" data-p2="98" data-p3="8200"
                aria-label="Call 4 1 6 - 3 9 8 - 8 2 0 0"
              >(416) 398-8200</a>
            </p>
            <p>
              <span class="footer-nap__fax">Fax: (416) 398-6745</span>
            </p>
          </address>

          <!-- Google Maps direction link -->
          <a
            href="https://maps.google.com/?q=3932A+Keele+St+North+York+ON+M3J+1N8"
            class="footer-nap__directions"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Get directions to Four Winds Roots Pharmacy on Google Maps (opens in new tab)"
          >
            Get Directions
          </a>
        </section>

        <!-- Hours block -->
        <!-- TODO: confirm exact hours with owner before publishing -->
        <section class="footer-hours" aria-labelledby="footer-hours-heading">
          <h2 id="footer-hours-heading" class="footer-hours__title">Hours</h2>
          <table class="footer-hours__table" aria-label="Pharmacy hours of operation">
            <caption class="sr-only">Four Winds Roots Pharmacy hours of operation</caption>
            <tbody>
              <tr>
                <th scope="row">Monday – Friday</th>
                <td><!-- TODO: confirm with owner -->9:00 am – 6:00 pm</td>
              </tr>
              <tr>
                <th scope="row">Saturday</th>
                <td><!-- TODO: confirm with owner -->9:00 am – 2:00 pm</td>
              </tr>
              <tr>
                <th scope="row">Sunday</th>
                <td><!-- TODO: confirm with owner -->Closed</td>
              </tr>
            </tbody>
          </table>
          <!-- TODO: add statutory holiday hours once confirmed with owner -->
          <p class="footer-hours__holiday-note">
            <em>Holiday hours may vary — call to confirm:
              <a
                href="#"
                class="tel-protected"
                data-p0="4" data-p1="163" data-p2="98" data-p3="8200"
                aria-label="Call 4 1 6 - 3 9 8 - 8 2 0 0"
              >(416) 398-8200</a>
            </em>
          </p>
        </section>

        <!-- Trust / regulatory note -->
        <section class="footer-trust" aria-labelledby="footer-trust-heading">
          <h2 id="footer-trust-heading" class="footer-trust__title">About Us</h2>
          <p class="footer-trust__ocp">
            <!-- TODO: add OCP registration number once confirmed with owner -->
            Registered with the <strong>Ontario College of Pharmacists</strong>.
          </p>
          <p class="footer-trust__rating">
            Rated <strong>4.9★</strong> by our community.
          </p>
        </section>

      </div>

      <!-- Footer bottom bar: legal links -->
      <div class="site-footer__bottom">
        <div class="container site-footer__bottom-inner">
          <p class="site-footer__copy">
            &copy; {new Date().getFullYear()} Four Winds Roots Pharmacy. All rights reserved.
          </p>
          <nav aria-label="Legal navigation" class="site-footer__legal-nav">
            <ul role="list">
              <li>
                <!-- TODO: create Privacy Policy page (PHIPA requirement) -->
                <a href="/privacy-policy">Privacy Policy</a>
              </li>
              <li>
                <!-- TODO: create Accessibility Statement page (AODA requirement) -->
                <a href="/accessibility">Accessibility Statement</a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </footer>

    <!-- ── Mobile action bar ────────────────────────────────────────────── -->
    <!--
      Fixed bottom bar, visible on mobile only (hidden via CSS on desktop).
      This is the single most important conversion component for mobile users.
    -->
    <div class="mobile-action-bar" role="navigation" aria-label="Mobile quick actions">
      <a
        href="#"
        class="mobile-action-bar__btn mobile-action-bar__btn--call tel-protected"
        data-p0="4" data-p1="163" data-p2="98" data-p3="8200"
        aria-label="Call 4 1 6 - 3 9 8 - 8 2 0 0"
      >
        <svg
          aria-hidden="true"
          focusable="false"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.6 4.38 2 2 0 0 1 3.57 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
        <span>Call</span>
      </a>

      <a href="/services/transfers" class="mobile-action-bar__btn mobile-action-bar__btn--transfer">
        <svg
          aria-hidden="true"
          focusable="false"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="17 1 21 5 17 9"></polyline>
          <path d="M3 11V9a4 4 0 0 1 4-4h14"></path>
          <polyline points="7 23 3 19 7 15"></polyline>
          <path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
        </svg>
        <span>Transfer Rx</span>
      </a>

      <a
        href="https://maps.google.com/?q=3932A+Keele+St+North+York+ON+M3J+1N8"
        class="mobile-action-bar__btn mobile-action-bar__btn--directions"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Get directions (opens Google Maps in new tab)"
      >
        <svg
          aria-hidden="true"
          focusable="false"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="3 11 22 2 13 21 11 13 3 11"></polygon>
        </svg>
        <span>Directions</span>
      </a>
    </div>

    <!-- ── Scripts ──────────────────────────────────────────────────────── -->
    <script>
      // ── Phone protection: assemble tel: href at runtime from data attributes ──
      // Scrapers reading the HTML source see href="#" — no harvestable phone number.
      // Aria-label on each element spells digits for screen readers.
      // Split: data-p0="4" + data-p1="163" + data-p2="98" + data-p3="8200" = 4163988200
      document.querySelectorAll<HTMLAnchorElement>('.tel-protected').forEach((el) => {
        const { p0, p1, p2, p3 } = el.dataset;
        if (p0 && p1 && p2 && p3) {
          el.href = 'tel:' + p0 + p1 + p2 + p3;
        }
      });

      // ── Mobile nav toggle ─────────────────────────────────────────────────
      const toggle = document.querySelector('.site-nav__toggle') as HTMLButtonElement | null;
      const navList = document.getElementById('main-nav-list');

      if (toggle && navList) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          navList.classList.toggle('is-open', !expanded);
        });

        // Close nav on Escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
            toggle.setAttribute('aria-expanded', 'false');
            navList.classList.remove('is-open');
            toggle.focus();
          }
        });
      }
    </script>

  </body>
</html>

<style>
  /* ── Header ────────────────────────────────────────────────────────────── */

  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: var(--color-paper);
    border-bottom: 2px solid var(--color-calm-light);
    box-shadow: var(--shadow-sm);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding-block: var(--space-4);
  }

  /* Logo */
  .logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo__text {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    line-height: 1.2;
  }

  /* Nav */
  .site-nav {
    flex: 1;
  }

  .site-nav__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-primary);
    font-size: var(--text-2xl);
    padding: var(--space-2);
  }

  .site-nav__list {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav__link {
    font-weight: var(--font-weight-medium);
    color: var(--color-ink);
    text-decoration: none;
    font-size: var(--text-base);
    transition: color var(--transition-fast);
  }

  .site-nav__link:hover {
    color: var(--color-primary);
  }

  /* Header CTAs */
  .site-header__ctas {
    display: flex;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  /* ── Footer ────────────────────────────────────────────────────────────── */

  .site-footer {
    background-color: var(--color-primary);
    color: var(--color-paper);
    margin-bottom: 5rem; /* clearance for mobile action bar */
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-8);
    padding-block: var(--space-12);
  }

  .site-footer a {
    color: var(--color-calm-light);
  }

  .site-footer a:hover {
    color: white;
  }

  .footer-nap__name,
  .footer-hours__title,
  .footer-trust__title {
    font-size: var(--text-lg);
    color: white;
    margin-bottom: var(--space-4);
  }

  .footer-nap__address {
    font-style: normal;
  }

  .footer-nap__address p {
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .footer-nap__directions {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: var(--font-weight-semibold);
  }

  .footer-hours__table {
    color: var(--color-calm-light);
  }

  .footer-hours__table th,
  .footer-hours__table td {
    padding: var(--space-1) var(--space-3) var(--space-1) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    font-size: var(--text-sm);
  }

  .footer-hours__table th {
    color: white;
    font-weight: var(--font-weight-medium);
  }

  .footer-hours__holiday-note {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    opacity: 0.8;
    max-width: none;
  }

  .footer-trust__ocp,
  .footer-trust__rating {
    color: var(--color-calm-light);
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .site-footer__bottom {
    background-color: rgba(0, 0, 0, 0.2);
    padding-block: var(--space-4);
  }

  .site-footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .site-footer__copy {
    font-size: var(--text-sm);
    color: var(--color-calm-light);
    opacity: 0.8;
    max-width: none;
    margin-bottom: 0;
  }

  .site-footer__legal-nav ul {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-footer__legal-nav a {
    font-size: var(--text-sm);
  }

  /* ── Mobile action bar ─────────────────────────────────────────────────── */

  .mobile-action-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: var(--z-mobile-bar);
    display: none; /* shown only on mobile via media query below */
    grid-template-columns: 1fr 1fr 1fr;
    background-color: var(--color-primary);
    border-top: 2px solid var(--color-action);
    box-shadow: 0 -2px 8px rgb(0 0 0 / 0.15);
  }

  .mobile-action-bar__btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-2);
    color: white;
    text-decoration: none;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background-color var(--transition-fast);
    min-height: 60px;
  }

  .mobile-action-bar__btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: white;
    opacity: 1;
  }

  .mobile-action-bar__btn--call {
    background-color: var(--color-action);
  }

  .mobile-action-bar__btn--transfer {
    background-color: var(--color-secondary);
  }

  .mobile-action-bar__btn--directions {
    background-color: var(--color-primary);
  }

  /* ── Responsive ────────────────────────────────────────────────────────── */

  @media (max-width: 768px) {
    .site-header__inner {
      flex-wrap: wrap;
      gap: var(--space-3);
    }

    .logo__text {
      font-size: var(--text-lg);
    }

    .site-nav {
      order: 3;
      width: 100%;
    }

    .site-nav__toggle {
      display: block;
    }

    .site-nav__list {
      display: none;
      flex-direction: column;
      gap: var(--space-1);
      padding: var(--space-4) 0;
      border-top: 1px solid var(--color-calm-light);
    }

    .site-nav__list.is-open {
      display: flex;
    }

    .site-nav__link {
      display: block;
      padding: var(--space-3) 0;
    }

    .site-header__ctas {
      order: 2;
      gap: var(--space-2);
    }

    .site-header__ctas .btn {
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-sm);
    }

    /* Show mobile action bar on phones */
    .mobile-action-bar {
      display: grid;
    }

    /* Extra bottom padding on footer so mobile bar doesn't overlap content */
    .site-footer {
      margin-bottom: 70px;
    }
  }

  @media (min-width: 769px) {
    /* Ensure mobile bar never shows on desktop */
    .mobile-action-bar {
      display: none !important;
    }

    .site-footer {
      margin-bottom: 0;
    }
  }
</style>

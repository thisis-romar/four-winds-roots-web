---
/**
 * SkipLink — Four Winds Roots Pharmacy
 * "Skip to main content" link for keyboard and screen-reader users.
 * WCAG 2.4.1 / AODA requirement — must be the first focusable element on the page.
 * Pattern: visually hidden until focused, then reveals with CSS transform.
 * Target: <main id="main-content">
 * TODO: Currently implemented inline in BaseLayout.astro — extract here for reuse.
 */
---

<a
  data-component="SkipLink"
  href="#main-content"
  class="skip-link"
>
  Skip to main content
</a>

<!--
  CSS lives in global.css:
  .skip-link {
    position: absolute; top: 1rem; left: 1rem;
    z-index: var(--z-modal);
    transform: translateY(-200%);
  }
  .skip-link:focus { transform: translateY(0); }
-->

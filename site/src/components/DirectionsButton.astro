---
/**
 * DirectionsButton — Four Winds Roots Pharmacy
 * One-tap link to Google Maps directions for 3932A Keele St, North York.
 * Opens in a new tab with rel="noopener noreferrer" for security.
 * Accessibility: aria-label warns that it opens in a new tab.
 * TODO: Consider adding Apple Maps fallback for iOS users (detect OS via JS, optional enhancement).
 *
 * Props:
 *   label?: string — button text (default: "Get Directions")
 *   variant?: 'btn' | 'link' (default: 'btn')
 */

interface Props {
  label?: string;
  variant?: 'btn' | 'link';
}

const { label = 'Get Directions', variant = 'btn' } = Astro.props;

const mapsUrl =
  'https://maps.google.com/?q=3932A+Keele+St+North+York+ON+M3J+1N8';
---

<a
  data-component="DirectionsButton"
  href={mapsUrl}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[variant === 'btn' && 'btn btn-outline']}
  aria-label="Get directions to Four Winds Roots Pharmacy on Google Maps (opens in new tab)"
>
  <svg
    aria-hidden="true"
    focusable="false"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <polygon points="3 11 22 2 13 21 11 13 3 11"></polygon>
  </svg>
  {label}
</a>

---
/**
 * PhoneLink.astro — Scraper-resistant click-to-call anchor
 *
 * Renders href="#" in static HTML (no harvestable tel: string in source).
 * BaseLayout's phone-assembly script reads .tel-protected elements and sets
 * the real tel: href at runtime, so real users get a working dial link.
 *
 * Includes a <noscript> fallback with a real tel: href — required by
 * WCAG 1.3.1 (Info and Relationships) for no-JS environments.
 *
 * Usage:
 *   <PhoneLink />                          → displays "(416) 398-8200"
 *   <PhoneLink class="footer-nap__phone" /> → preserves styling class
 *   <PhoneLink display="Call us" />        → custom display text
 *
 * Split: "4" + "163" + "98" + "8200" = "4163988200" (no fragment is a full number)
 */

interface Props {
  class?: string;
  display?: string;
  label?: string;
}

const {
  class: className = '',
  display = '(416) 398-8200',  // non-breaking space between area and exchange
  label = 'Call 4 1 6 - 3 9 8 - 8 2 0 0',
} = Astro.props;
---

<a
  href="#"
  class:list={['tel-protected', className].filter(Boolean)}
  data-p0="4"
  data-p1="163"
  data-p2="98"
  data-p3="8200"
  aria-label={label}
>{display}</a><noscript><a
  href="tel:4163988200"
  class={className || undefined}
  aria-label={label}
>{display}</a></noscript>

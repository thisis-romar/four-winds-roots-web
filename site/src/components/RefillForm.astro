---
/**
 * RefillForm — Four Winds Roots Pharmacy
 * PHIPA-safe prescription refill request form.
 * Collects: Rx number(s), patient name, contact, pickup/delivery choice, consent.
 *
 * PHIPA / COMPLIANCE REQUIREMENTS (see design/compliance-checklist.md):
 * - Explicit informed consent checkbox
 * - HTTPS-only POST to compliant backend (TODO: wire up Netlify Forms or server function)
 * - Minimal data — only what's needed to locate and prepare the prescription
 * - Honeypot for spam prevention without blocking assistive tech
 * - Success + failure states with phone fallback
 *
 * TODO: Wire up form action to a PHIPA-compliant backend before go-live.
 * TODO: Have consent language reviewed by owner and OCP before publishing.
 */
import PhoneLink from './PhoneLink.astro';
---

<form
  data-component="RefillForm"
  class="pharmacy-form"
  method="POST"
  action="TODO_FORM_ENDPOINT"
  aria-label="Prescription refill request form"
  novalidate
>
  <fieldset>
    <legend>Your Prescription</legend>
    <div class="form-group">
      <label for="refill-rx-number">
        Prescription Number(s)
        <span class="form-hint">Found on your prescription label</span>
      </label>
      <input
        type="text"
        id="refill-rx-number"
        name="rx_number"
        autocomplete="off"
        placeholder="e.g., RX-12345"
        aria-describedby="refill-rx-hint"
      />
      <span id="refill-rx-hint" class="form-hint">
        If you don't have the number, that's okay — we can look it up with your name.
      </span>
    </div>
  </fieldset>

  <fieldset>
    <legend>Your Information</legend>
    <div class="form-group">
      <label for="refill-patient-name">Your Full Name <span aria-hidden="true">*</span></label>
      <input
        type="text"
        id="refill-patient-name"
        name="patient_name"
        required
        aria-required="true"
        autocomplete="name"
      />
    </div>
    <div class="form-group">
      <label for="refill-patient-dob">Date of Birth <span aria-hidden="true">*</span></label>
      <input
        type="date"
        id="refill-patient-dob"
        name="patient_dob"
        required
        aria-required="true"
        autocomplete="bday"
      />
    </div>
    <div class="form-group">
      <label for="refill-contact-phone">Your Phone Number <span aria-hidden="true">*</span></label>
      <input
        type="tel"
        id="refill-contact-phone"
        name="contact_phone"
        required
        aria-required="true"
        autocomplete="tel"
        placeholder="(xxx) xxx-xxxx"
      />
    </div>
  </fieldset>

  <fieldset>
    <legend>Pickup or Delivery</legend>
    <div class="form-group form-group--radio">
      <label>
        <input type="radio" name="fulfillment" value="pickup" checked />
        I'll pick it up at the pharmacy
      </label>
      <label>
        <input type="radio" name="fulfillment" value="delivery" />
        Free delivery to my address
      </label>
    </div>
    <div class="form-group" id="refill-delivery-address-group">
      <label for="refill-delivery-address">Delivery Address</label>
      <input
        type="text"
        id="refill-delivery-address"
        name="delivery_address"
        autocomplete="street-address"
        placeholder="Your delivery address in North York"
      />
    </div>
  </fieldset>

  <!-- Honeypot spam prevention -->
  <div aria-hidden="true" style="display: none; visibility: hidden; position: absolute;">
    <label for="refill-website">Leave this blank</label>
    <input type="text" id="refill-website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Explicit informed consent -->
  <div class="form-group form-group--consent">
    <label class="form-consent-label">
      <input
        type="checkbox"
        name="consent"
        required
        aria-required="true"
        aria-describedby="refill-consent-description"
      />
      <span id="refill-consent-description">
        <!-- TODO: have consent language reviewed by owner and OCP before publishing -->
        I consent to Four Winds Roots Pharmacy using the above information to process my
        prescription refill request. My information will be handled in accordance with PHIPA.
        <a href="/privacy-policy">Privacy Policy</a>
      </span>
    </label>
  </div>

  <button type="submit" class="btn btn-call">Request Refill</button>

  <!-- TODO: Implement success and error states -->
  <div role="status" aria-live="polite" class="form-status" id="refill-form-status"></div>

  <p class="form-fallback">
    Prefer to call? <PhoneLink />
  </p>
</form>

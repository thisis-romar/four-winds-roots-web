---
/**
 * RefillForm — Four Winds Roots Pharmacy
 * PHIPA-safe prescription refill request form.
 * Collects: Rx number(s), patient name, contact, pickup/delivery choice, consent.
 *
 * PHIPA / COMPLIANCE REQUIREMENTS (see design/compliance-checklist.md):
 * - Explicit informed consent checkbox
 * - HTTPS-only POST to compliant backend (TODO: wire up Netlify Forms or server function)
 * - Minimal data — only what's needed to locate and prepare the prescription
 * - Honeypot for spam prevention without blocking assistive tech
 * - Success + failure states with phone fallback
 *
 * TODO: Wire up form action to a PHIPA-compliant backend before go-live.
 * TODO: Have consent language reviewed by owner and OCP before publishing.
 */
import PhoneLink from './PhoneLink.astro';
---

<!--
  Online refill form temporarily DISABLED. It collected PHIPA-protected health data but had no
  compliant backend wired. Until a PHIPA-safe vendor is selected
  (see research/phipa-vendor-comparison.md), we direct patients to call/fax/visit instead.
  The full original form markup is preserved in git history — restore it once a backend exists.
-->
<div class="pharmacy-form-cta" role="note" aria-labelledby="refill-cta-heading">
  <h3 id="refill-cta-heading">Request a refill — call, fax, or visit</h3>
  <p>
    Online refill requests are coming soon. For now, the fastest way to refill is to reach our
    pharmacy team directly:
  </p>
  <ul>
    <li>
      <strong>Call us:</strong> <PhoneLink /> — have your prescription number (on your label) or
      your name and date of birth ready.
    </li>
    <li><strong>Fax us:</strong> (416) 398-6745</li>
    <li><strong>Visit us:</strong> 3932A Keele St, North York, ON M3J 1N8</li>
  </ul>
  <p class="pharmacy-form-cta__action">
    <PhoneLink class="btn btn-call" display="Call (416) 398-8200" />
  </p>
</div>

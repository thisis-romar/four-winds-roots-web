---
/**
 * DeliveryRequestForm — Four Winds Roots Pharmacy
 * PHIPA-safe delivery request form.
 * Collects: delivery address, preferred time window, consent.
 * Minimal health data — does not collect medication details here (handled at fulfillment).
 *
 * PHIPA / COMPLIANCE REQUIREMENTS (see design/compliance-checklist.md):
 * - Explicit informed consent checkbox
 * - HTTPS-only POST to compliant backend (TODO: wire up before go-live)
 * - Minimal data collection — address + contact only
 * - Honeypot for spam prevention
 * - Success + failure states with phone fallback
 *
 * TODO: Wire up form action to a PHIPA-compliant backend before go-live.
 * TODO: Confirm delivery coverage area and time windows with owner.
 */
import PhoneLink from './PhoneLink.astro';
---

<!--
  Online delivery-request form temporarily DISABLED. It collected PHIPA-protected data but had no
  compliant backend wired. Until a PHIPA-safe vendor is selected
  (see research/phipa-vendor-comparison.md), we direct patients to call/visit instead.
  The full original form markup is preserved in git history — restore it once a backend exists.
-->
<div class="pharmacy-form-cta" role="note" aria-labelledby="delivery-cta-heading">
  <h3 id="delivery-cta-heading">Arrange free delivery — give us a call</h3>
  <p>
    Online delivery requests are coming soon. To set up free delivery now, just call our pharmacy
    team and we'll arrange it with you:
  </p>
  <ul>
    <li><strong>Call us:</strong> <PhoneLink /> — have your delivery address and phone number ready.</li>
    <li><strong>Visit us:</strong> 3932A Keele St, North York, ON M3J 1N8</li>
  </ul>
  <p class="pharmacy-form-cta__action">
    <PhoneLink class="btn btn-call" display="Call (416) 398-8200" />
  </p>
</div>

      <table aria-label="Pharmacy hours of operation">
        <caption class="sr-only">Four Winds Roots Pharmacy hours of operation</caption>
        <tbody>
          <tr>
            <th scope="row">Monday</th>
            <td><!-- TODO: confirm -->9:00 am – 6:00 pm</td>

            <td><!-- TODO: confirm -->9:00 am – 2:00 pm</td>
          </tr>
          <tr>
            <th scope="row">Sunday</th>
            <td><!-- TODO: confirm -->Closed</td>
          </tr>
        </tbody>
      </table>
      <p>
        <em>

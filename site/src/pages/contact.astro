    <section aria-labelledby="contact-form-heading">
      <h2 id="contact-form-heading">Send Us a Message</h2>
      <p>
        <strong>For prescriptions and health information, please call us directly:</strong>
        <PhoneLink />
      </p>
      <!-- Simple general contact form — no PHIPA-sensitive data collected here -->
      <!-- TODO: implement contact form (name, email/phone, general message only) -->
      <p>TODO: Simple contact form — name, phone or email, general message. No health/prescription data.</p>
    </section>

    <section aria-labelledby="contact-fax-heading">
      <h2 id="contact-fax-heading">For Healthcare Providers</h2>
      <p>Send prescriptions and referrals by fax: <strong>(416) 398-6745</strong></p>
    </section>
  </div>
</BaseLayout>

<style>
  .contact-call-first {
    background-color: var(--color-calm-light);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
    text-align: center;
  }

  .contact-call-big {
    font-size: var(--text-2xl);
    padding: var(--space-4) var(--space-10);
    margin-block: var(--space-4);
  }

  address {
    font-style: normal;
    margin-bottom: var(--space-4);
  }

  address p {
    margin-bottom: var(--space-2);
  }
</style>

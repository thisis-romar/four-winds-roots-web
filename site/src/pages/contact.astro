import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneLink from '../components/PhoneLink.astro';
---

<BaseLayout
  title="Contact, Hours & Location | Four Winds Roots Pharmacy, Keele & Finch"
  description="Contact Four Winds Roots Pharmacy at Keele & Finch, North York. Phone: (416) 398-8200. Hours, Google Maps, parking, transit, and fax information. 3932A Keele St, M3J 1N8."
>
  <!--
    IA KEY BLOCKS (from information-architecture.md — Contact / Location / Hours):
    1. Click-to-call — very prominent, first thing on the page (the conversion backstop)
    2. Google Maps embed — lazy-loaded iframe for 3932A Keele St, North York
    3. Full NapBlock — address, phone, fax, consistent with GBP and schema
    4. Full hours table — all days including weekends + holiday hours note
       TODO: confirm all hours with owner, including holiday hours
    5. Parking & transit note — how to get there (TTC on Keele, parking nearby)
       TODO: add parking/transit details with owner input
    6. After-hours / emergency instructions — what to do when the pharmacy is closed
       TODO: confirm after-hours referral info with owner (Telehealth Ontario, 911, etc.)
    7. Simple contact form — name, phone/email, message (not PHIPA-critical, no health data)
    8. Fax number — for prescribers and healthcare providers
    Primary keyword: "pharmacy Keele and Finch hours", "pharmacy open weekends North York"
    NOTE: this is the conversion backstop — every visitor who doesn't convert elsewhere lands here.
  -->

  <div class="container section">
    <h1>Contact &amp; Location — Four Winds Roots Pharmacy</h1>

    <!-- Prominent call CTA — top of page, before anything else -->
    <section aria-labelledby="contact-call-heading" class="contact-call-first">
      <h2 id="contact-call-heading">Call Us Now</h2>
      <PhoneLink class="btn btn-call contact-call-big" display="(416) 398-8200" />
      <p>
        <!-- TODO: confirm hours with owner -->
        Mon–Fri 9 am–6 pm &nbsp;·&nbsp; Sat 9 am–2 pm
      </p>
    </section>

    <section aria-labelledby="contact-nap-heading">
      <h2 id="contact-nap-heading">Find Us</h2>
      <!-- NapBlock — canonical NAP, must match GBP and schema.json exactly -->
      <address aria-label="Pharmacy address and contact">
        <p>
          <strong>Four Winds Roots Pharmacy</strong><br />
          3932A Keele St<br />
          North York, ON M3J 1N8
        </p>
        <p>
          Phone: <PhoneLink />
        </p>
        <p>
          Fax: (416) 398-6745
        </p>
      </address>
      <a
        href="https://maps.google.com/?q=3932A+Keele+St+North+York+ON+M3J+1N8"
        class="btn btn-outline"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Get directions on Google Maps (opens in new tab)"

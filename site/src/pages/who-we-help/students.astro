        <!-- TODO: confirm whether TTC bus routes on Keele St are also relevant for on-campus riders -->
      </p>
    </section>

    <section aria-labelledby="students-cta">
      <h2 id="students-cta">Get Started</h2>
      <p>
        <a href="/services/transfers" class="btn btn-transfer">Transfer My Rx</a>
        <PhoneLink class="btn btn-call" display="Call Us" />
